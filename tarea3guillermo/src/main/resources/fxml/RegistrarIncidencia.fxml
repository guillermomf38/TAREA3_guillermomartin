<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.luisdbb.tarea3AD2024base.controller.RegistrarIncidenciaController">

    <top>
        <HBox alignment="CENTER" prefHeight="100.0" style="-fx-background-color: #E57373;">
            <Button fx:id="btnAtras" onAction="#atras" style="-fx-background-color: white;" text="Atrás">
                <HBox.margin><Insets right="100.0" /></HBox.margin>
            </Button>
            <Label text="Registrar Incidencia">
                <font><Font name="Britannic Bold" size="32.0" /></font>
            <HBox.margin>
               <Insets right="150.0" />
            </HBox.margin>
            </Label>
        </HBox>
    </top>

    <center>
        <VBox alignment="TOP_CENTER" spacing="15.0" style="-fx-background-color: lightskyblue;">
            <padding><Insets left="50.0" right="50.0" top="30.0" /></padding>

            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label prefWidth="130" text="Tipo:">
                    <font><Font name="Arial" size="14.0" /></font>
                </Label>
                <ComboBox fx:id="cbTipo" prefWidth="300.0" />
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label prefWidth="130" text="Descripción:">
                    <font><Font name="Arial" size="14.0" /></font>
                </Label>
                <TextArea fx:id="taDescripcion" prefHeight="150.0" prefWidth="300.0" wrapText="true" />
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label prefWidth="130" text="Espectáculo:">
                    <font><Font name="Arial" size="14.0" /></font>
                </Label>
                <ComboBox fx:id="cbEspectaculo" prefWidth="300.0" />
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label prefWidth="130" text="Número:">
                    <font><Font name="Arial" size="14.0" /></font>
                </Label>
                <ComboBox fx:id="cbNumero" prefWidth="300.0" />
            </HBox>

            <Button fx:id="btnRegistrar" onAction="#registrar" prefWidth="250.0" style="-fx-background-color: white;" text="Registrar Incidencia">
                <font><Font name="Arial" size="14.0" /></font>
                <VBox.margin><Insets top="20.0" /></VBox.margin>
            </Button>

        </VBox>
    </center>
</BorderPane>
