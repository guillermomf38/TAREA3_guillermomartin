<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.luisdbb.tarea3AD2024base.controller.ModificarPersonaController">

  
    <top>
        <HBox alignment="CENTER" prefHeight="100.0" style="-fx-background-color: #E57373;">
            <Button fx:id="btnAtras" onAction="#atras" style="-fx-background-color: white;" text="Atrás">
            <HBox.margin>
               <Insets right="200.0" />
            </HBox.margin></Button>
            <Label text="Modificar Persona">
                <font><Font name="Britannic Bold" size="36.0" /></font>
            <HBox.margin>
               <Insets right="300.0" />
            </HBox.margin>
            </Label>
        </HBox>
    </top>

    <left>
        <VBox alignment="TOP_CENTER" fillWidth="true" minWidth="350.0" prefWidth="350.0" spacing="15.0" style="-fx-background-color: lightskyblue;">

            <padding>
                <Insets left="15.0" right="15.0" top="20.0" />
            </padding>

            <Label text="Selecciona persona:">
                <font><Font name="Arial" size="14.0" /></font>
            </Label>

            <!-- LISTVIEW ARREGLADO -->
            <ListView fx:id="lvPersonas" maxWidth="Infinity" VBox.vgrow="ALWAYS" />

            <Label style="-fx-font-weight: bold;" text="Datos Personales">
                <font><Font name="Arial" size="15.0" /></font>
                <VBox.margin>
                    <Insets top="10.0" />
                </VBox.margin>
            </Label>

            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label prefWidth="90" text="Nombre:">
                    <font><Font name="Arial" size="13.0" /></font>
                </Label>
                <TextField fx:id="txtNombre" prefWidth="190.0" />
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label prefWidth="90" text="Email:">
                    <font><Font name="Arial" size="13.0" /></font>
                </Label>
                <TextField fx:id="txtEmail" prefWidth="190.0" />
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label prefWidth="90" text="Nacionalidad:">
                    <font><Font name="Arial" size="13.0" /></font>
                </Label>
                <ChoiceBox fx:id="cbNacionalidad" prefWidth="190.0" />
            </HBox>

        </VBox>
    </left>


    <center>
        <VBox alignment="TOP_CENTER" prefWidth="620.0" spacing="15.0" style="-fx-background-color: lightskyblue;">

            <padding>
                <Insets left="20.0" right="20.0" top="20.0" />
            </padding>

            <Label fx:id="lblTipoPerfil" style="-fx-font-weight: bold;" text="Selecciona una persona">
                <font><Font name="Arial" size="16.0" /></font>
            </Label>
         <HBox prefHeight="479.0" prefWidth="610.0">
            <children>
               <VBox fx:id="panelArtista" prefHeight="466.0" prefWidth="290.0">
                  <children>
                     <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="40.0">
                        <children>
                           <Label text="Apodo" />
                           <TextField fx:id="txtApodo" />
                        </children>
                     </HBox>
                     <Label text="Especialidades:">
                        <VBox.margin>
                           <Insets left="30.0" />
                        </VBox.margin>
                     </Label>
                     <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
                        <children>
                           <CheckBox fx:id="ckAcrobacia" mnemonicParsing="false" text="Acrobacia" />
                           <CheckBox fx:id="ckHumor" mnemonicParsing="false" text="Humor" />
                           <CheckBox fx:id="ckMagia" mnemonicParsing="false" text="Magia" />
                        </children>
                     </HBox>
                     <HBox alignment="TOP_CENTER" prefHeight="100.0" prefWidth="200.0">
                        <children>
                           <CheckBox fx:id="ckEquilibrismo" mnemonicParsing="false" text="Equilibrismo" />
                           <CheckBox fx:id="ckMalabarismo" mnemonicParsing="false" text="Malabarismo" />
                        </children>
                     </HBox>
                  </children>
               </VBox>
               <VBox fx:id="panelCoord" prefHeight="200.0" prefWidth="345.0">
                  <children>
                     <HBox alignment="CENTER" prefHeight="148.0" prefWidth="333.0" spacing="40.0">
                        <children>
                           <Label text="¿Senior?" />
                           <CheckBox fx:id="ckSenior" mnemonicParsing="false" />
                        </children>
                     </HBox>
                     <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="40.0">
                        <children>
                           <Label text="Fecha Senior:" />
                           <DatePicker fx:id="dpFechaSenior" />
                        </children>
                     </HBox>
                  </children>
               </VBox>
            </children>
         </HBox>

        </VBox>
    </center>

   
    <bottom>
        <HBox alignment="CENTER" prefHeight="80.0" spacing="80.0" style="-fx-background-color: lightskyblue;">

            <Button fx:id="btnGuardar" onAction="#guardar" prefWidth="130.0" style="-fx-background-color: white;" text="Guardar">
                <font><Font name="Arial" size="14.0" /></font>
            </Button>

            <Button fx:id="btnReiniciar" onAction="#reiniciar" prefWidth="130.0" style="-fx-background-color: #E57373; -fx-text-fill: white;" text="Reiniciar">
                <font><Font name="Arial" size="14.0" /></font>
            </Button>

        </HBox>
    </bottom>

</BorderPane>
