<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.luisdbb.tarea3AD2024base.controller.GestionarEspectaculoController">

    <top>
        <HBox alignment="CENTER" prefHeight="100.0" style="-fx-background-color: #E57373;">
            <Button fx:id="btnAtras" onAction="#atras" style="-fx-background-color: white;" text="Atrás">
                <HBox.margin><Insets right="150.0" /></HBox.margin>
            </Button>
            <Label text="Gestionar Espectáculos">
                <font><Font name="Britannic Bold" size="36.0" /></font>
                <HBox.margin><Insets right="200.0" /></HBox.margin>
            </Label>
        </HBox>
    </top>

    <left>
        <VBox alignment="TOP_CENTER" prefWidth="280.0" spacing="10.0" style="-fx-background-color: lightskyblue;">
            <padding><Insets left="10.0" right="10.0" top="20.0" /></padding>

            <Label text="Espectáculos:">
                <font><Font name="Arial" size="14.0" /></font>
            </Label>
            <ListView fx:id="lvEspectaculos" prefHeight="380.0" prefWidth="250.0" />
            <Button fx:id="btnNuevoEspectaculo" onAction="#nuevoEspectaculo" prefWidth="200.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="Nuevo Espectáculo">
                <font><Font name="Arial" size="13.0" /></font>
            </Button>
        </VBox>
    </left>

    <center>
        <VBox alignment="TOP_CENTER" prefWidth="380.0" spacing="12.0" style="-fx-background-color: lightskyblue;">
            <padding><Insets left="15.0" right="15.0" top="20.0" /></padding>

            <Label style="-fx-font-weight: bold;" text="Datos del Espectáculo">
                <font><Font name="Arial" size="15.0" /></font>
            </Label>

            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label prefWidth="100" text="Nombre:">
                    <font><Font name="Arial" size="13.0" /></font>
                </Label>
                <TextField fx:id="txtNombreEsp" prefWidth="220.0" />
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label prefWidth="100" text="Fecha inicio:">
                    <font><Font name="Arial" size="13.0" /></font>
                </Label>
                <DatePicker fx:id="dpFechaini" prefWidth="220.0" />
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label prefWidth="100" text="Fecha fin:">
                    <font><Font name="Arial" size="13.0" /></font>
                </Label>
                <DatePicker fx:id="dpFechafin" prefWidth="220.0" />
            </HBox>

            <HBox fx:id="hboxCoord" alignment="CENTER_LEFT" spacing="10.0">
                <Label prefWidth="100" text="Coordinador:">
                    <font><Font name="Arial" size="13.0" /></font>
                </Label>
                <ComboBox fx:id="cbCoordinador" prefWidth="220.0" />
            </HBox>

            <HBox alignment="CENTER" spacing="10.0">
                <Button fx:id="BtnGuardarEspectaculo" onAction="#guardarEspectaculo" prefWidth="160.0" style="-fx-background-color: white;" text="Guardar Espectáculo">
                    <font><Font name="Arial" size="13.0" /></font>
                </Button>
                <Button fx:id="btnLimpiarEspectaculo" onAction="#limpiarEspectaculo" prefWidth="80.0" style="-fx-background-color: #E57373; -fx-text-fill: white;" text="Limpiar">
                    <font><Font name="Arial" size="13.0" /></font>
                </Button>
            </HBox>

            <Label style="-fx-font-weight: bold;" text="Números del Espectáculo">
                <font><Font name="Arial" size="15.0" /></font>
                <VBox.margin><Insets top="10.0" /></VBox.margin>
            </Label>

            <ListView fx:id="lvNumeros" prefHeight="150.0" prefWidth="340.0" />

            <HBox alignment="CENTER" spacing="10.0">
                <Button fx:id="btnNuevoNumero" onAction="#nuevoNumero" prefWidth="130.0" style="-fx-background-color: #5B9BD5; -fx-text-fill: white;" text="Nuevo Número">
                    <font><Font name="Arial" size="13.0" /></font>
                </Button>
                <Button fx:id="btnEditarNumero" onAction="#editarNumero" prefWidth="130.0" style="-fx-background-color: white;" text="Editar Número">
                    <font><Font name="Arial" size="13.0" /></font>
                </Button>
            </HBox>
        </VBox>
    </center>

    <right>
        <VBox alignment="TOP_CENTER" prefWidth="300.0" spacing="12.0" style="-fx-background-color: lightskyblue;">
            <padding><Insets left="10.0" right="10.0" top="20.0" /></padding>

            <Label style="-fx-font-weight: bold;" text="Datos del Número">
                <font><Font name="Arial" size="15.0" /></font>
            </Label>

            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label prefWidth="80" text="Nombre:">
                    <font><Font name="Arial" size="13.0" /></font>
                </Label>
                <TextField fx:id="txtNombreNum" prefWidth="180.0" />
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label prefWidth="80" text="Duración:">
                    <font><Font name="Arial" size="13.0" /></font>
                </Label>
                <TextField fx:id="txtDuracion" prefWidth="180.0" />
            </HBox>

            <Button fx:id="btnGuardarNumero" onAction="#guardarNumero" prefWidth="200.0" style="-fx-background-color: white;" text="Guardar Número">
                <font><Font name="Arial" size="13.0" /></font>
            </Button>

            <Label style="-fx-font-weight: bold;" text="Artistas del Número">
                <font><Font name="Arial" size="15.0" /></font>
                <VBox.margin><Insets top="10.0" /></VBox.margin>
            </Label>

            <ListView fx:id="lvArtistas" prefHeight="200.0" prefWidth="270.0" />

            <Button fx:id="btnAsignarArtistas" onAction="#asignarArtistas" prefWidth="200.0" style="-fx-background-color: #5B9BD5; -fx-text-fill: white;" text="Asignar Artistas">
                <font><Font name="Arial" size="13.0" /></font>
            </Button>
        </VBox>
    </right>

</BorderPane>
