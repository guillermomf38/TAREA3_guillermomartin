<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.luisdbb.tarea3AD2024base.controller.ActualizarDossierController">

    <top>
        <HBox alignment="CENTER" prefHeight="100.0" style="-fx-background-color: #E57373;">
            <Button fx:id="btnAtras" onAction="#atras" style="-fx-background-color: white;" text="Atrás">
                <HBox.margin><Insets right="150.0" /></HBox.margin>
            </Button>
            <Label text="Actualizar Dossier Artístico">
                <font><Font name="Britannic Bold" size="30.0" /></font>
            <HBox.margin>
               <Insets right="100.0" />
            </HBox.margin>
            </Label>
        </HBox>
    </top>

    <left>
        <VBox alignment="TOP_CENTER" prefWidth="280.0" spacing="10.0" style="-fx-background-color: lightskyblue;">
            <padding><Insets left="10.0" right="10.0" top="20.0" /></padding>

            <Label style="-fx-font-weight: bold;" text="Selecciona artista:">
                <font><Font name="Arial" size="14.0" /></font>
            </Label>
            <ListView fx:id="lvArtistas" prefHeight="400.0" prefWidth="260.0" />
        </VBox>
    </left>

    <center>
        <VBox alignment="TOP_CENTER" spacing="15.0" style="-fx-background-color: lightskyblue;">
            <padding><Insets left="20.0" right="20.0" top="20.0" /></padding>

           
            <Label style="-fx-font-weight: bold;" text="Dossier actual:">
                <font><Font name="Arial" size="15.0" /></font>
            </Label>
            <TextArea fx:id="taDossierActual" editable="false" prefHeight="200.0" wrapText="true" />

           
            <Label style="-fx-font-weight: bold;" text="Añadir Evaluación:">
                <font><Font name="Arial" size="14.0" /></font>
            </Label>

            <HBox alignment="CENTER" spacing="20.0">
                <Label prefHeight="18.0" prefWidth="74.0" text="Comentario:" />
                <TextField fx:id="txtComentario" prefHeight="60.0" prefWidth="300.0" />
            </HBox>

            <HBox alignment="CENTER" spacing="30.0">
                <Label prefHeight="18.0" prefWidth="66.0" text="Nivel:" />
                <ComboBox fx:id="cbNivel" prefHeight="26.0" prefWidth="298.0" />
            </HBox>

            <Button fx:id="btnAñadirEvaluacion" alignment="CENTER" onAction="#añadirEvaluacion" prefHeight="24.0" prefWidth="162.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="Añadir Evaluación">
                <font><Font name="Arial" size="13.0" /></font>
            </Button>

           
            <Label style="-fx-font-weight: bold;" text="Añadir Observación:">
                <font><Font name="Arial" size="14.0" /></font>
            </Label>

            <HBox alignment="CENTER" spacing="10.0">
                <Label prefWidth="90" text="Observación:" />
                <TextField fx:id="txtObservacion" prefHeight="60.0" prefWidth="300.0" />
            </HBox>

            <Button fx:id="btnAñadirObservacion" onAction="#añadirObservacion" prefWidth="162.0" style="-fx-background-color: #5B9BD5; -fx-text-fill: white;" text="Añadir Observación">
                <font><Font name="Arial" size="13.0" /></font>
            </Button>

        </VBox>
    </center>

</BorderPane>
